# =============================================================================
# DailyDefense — sample environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# `.env` is gitignored (see .gitignore). Do NOT commit secrets.
# When running with Docker Compose, this file is loaded via `env_file:` in
# docker-compose.yml, so changes here take effect on `docker compose up`.
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Display name used in the FastAPI title and HUD.
APP_NAME=DailyDefense

# Bind address inside the container. Leave as 0.0.0.0 unless you know better.
APP_HOST=0.0.0.0

# Application port. Must match the published port in docker-compose.yml.
APP_PORT=8014

# `development` enables uvicorn auto-reload when running locally (not in Docker).
# Use `production` for any deployment.
ENVIRONMENT=development


# -----------------------------------------------------------------------------
# Sessions
# -----------------------------------------------------------------------------
# Signing key for the session cookie. MUST be set to a long random string in
# any non-local environment. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=replace-with-a-long-random-string


# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Directory used by the score store. In Docker this is mounted as the
# `dailydefense-data` named volume, so high scores survive container restarts.
# Override only if you want scores written elsewhere (e.g. for local dev).
DATA_DIR=/app/data


# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Google SSO is OFF by default. The current game does not require sign-in.
# Set to `true` to enable the /auth/login and /auth/callback endpoints and
# show the "Sign in with Google" link on the index page.
AUTH_ENABLED=false

# Google OAuth credentials. Only needed when AUTH_ENABLED=true.
# Create them at: https://console.cloud.google.com/apis/credentials
#   - Application type: Web application
#   - Authorized redirect URI: must match GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8014/auth/callback
