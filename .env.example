# DailyDefense environment configuration
# Copy this file to .env and fill in real values. The .env file is gitignored.

# Application
APP_NAME=DailyDefense
APP_HOST=0.0.0.0
APP_PORT=8014
ENVIRONMENT=development

# Session signing key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SESSION_SECRET=replace-with-a-long-random-string

# Authentication
# Set to true to enable Google SSO. When false (default), /auth/* endpoints return 404
# and the index page does not show a sign-in link.
AUTH_ENABLED=false

# Google SSO (https://console.cloud.google.com/apis/credentials)
# Only required when AUTH_ENABLED=true.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8014/auth/callback
